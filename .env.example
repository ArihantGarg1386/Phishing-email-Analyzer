# Copy this file to .env and fill in your own API keys.
# Both services offer free tiers that are more than sufficient for this tool.

# VirusTotal: https://www.virustotal.com/gui/join-us
VT_API_KEY=YOUR_VIRUSTOTAL_API_KEY_HERE

# Google Safe Browsing: https://developers.google.com/safe-browsing/v4/get-started
GSB_API_KEY=YOUR_GOOGLE_SAFE_BROWSING_API_KEY_HERE
